rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', null) == 'admin';
    }

    function isScorekeeper() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', null) in ['admin', 'scorekeeper'];
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isOrganizer() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', null) == 'organizer';
    }

    function isOrganizerOf(tournamentId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/tournaments/$(tournamentId)) &&
        request.auth.uid in get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.get('organizerIds', []);
    }

    // Users collection
    match /users/{userId} {
      // Users can read their own profile, admins can read all
      allow read: if isAuthenticated();
      // Users can create their own profile on signup
      allow create: if isAuthenticated();
      // Users can update their own profile (except role), admins can update any
      allow update: if isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
                    || isAdmin();
      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // Tournaments collection
    match /tournaments/{tournamentId} {
      // Anyone can read published tournaments
      allow read: if true;
      // Admins or organizers can create tournaments
      allow create: if isAdmin() || isOrganizer();
      // Only admins or organizers assigned to this tournament can update it
      allow update: if isAdmin() || isOrganizer() || isOrganizerOf(tournamentId);
      allow delete: if isAdmin();

      // Categories subcollection
      match /categories/{categoryId} {
        allow read: if true;
        allow write: if isAdmin() || isOrganizerOf(tournamentId);
      }

      // Courts subcollection
      match /courts/{courtId} {
        allow read: if true;
        allow write: if isAdmin() || isOrganizerOf(tournamentId);
      }

      // Players subcollection
      match /players/{playerId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow update: if isAdmin() || isOrganizerOf(tournamentId);
        allow delete: if isAdmin() || isOrganizerOf(tournamentId);
      }

      // Registrations subcollection
      match /registrations/{registrationId} {
        allow read: if true;
        // Anyone authenticated can self-register
        allow create: if isAuthenticated();
        // Only tournament organizers or admins can approve/reject
        allow update: if isAdmin() || isOrganizerOf(tournamentId);
        allow delete: if isAdmin() || isOrganizerOf(tournamentId);
      }

      // Activities subcollection (tournament activity feed)
      match /activities/{activityId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow update: if isAdmin() || isOrganizerOf(tournamentId);
        allow delete: if isAdmin() || isOrganizerOf(tournamentId);
      }
      // Brackets Manager Collections
      // stage subcollection
      match /stage/{stageId} {
        allow read: if true;
        allow write: if isAdmin() || isOrganizerOf(tournamentId);
      }

      // match subcollection (singular 'match' used by brackets-manager)
      match /match/{matchId} {
        allow read: if true;
        allow write: if isAdmin() || isOrganizerOf(tournamentId) || isScorekeeper();
      }

      // participant subcollection
      match /participant/{participantId} {
        allow read: if true;
        allow write: if isAdmin() || isOrganizerOf(tournamentId);
      }

      // group subcollection
      match /group/{groupId} {
        allow read: if true;
        allow write: if isAdmin() || isOrganizerOf(tournamentId);
      }

      // round subcollection
      match /round/{roundId} {
        allow read: if true;
        allow write: if isAdmin() || isOrganizerOf(tournamentId);
      }

      // match_game subcollection (for game scores)
      match /match_game/{gameId} {
        allow read: if true;
        allow write: if isAdmin() || isOrganizerOf(tournamentId) || isScorekeeper();
      }

      // match_scores subcollection (for legacy/custom scoring)
      match /match_scores/{matchId} {
        allow read: if true;
        allow write: if isAdmin() || isOrganizerOf(tournamentId) || isScorekeeper();

        // Score correction history - readable by all, writable by scorekeepers only
        match /corrections/{correctionId} {
          allow read: if isAuthenticated();
          allow create: if isScorekeeper();
          allow update, delete: if false; // Immutable history
        }
      }

      // Category-isolated bracket collections (new architecture)
      match /categories/{categoryId} {
        allow read: if true;
        allow write: if isAdmin() || isOrganizerOf(tournamentId);

        // Bracket subcollections under each category
        match /stage/{stageId} {
          allow read: if true;
          allow write: if isAdmin() || isOrganizerOf(tournamentId);
        }

        match /match/{matchId} {
          allow read: if true;
          allow write: if isAdmin() || isOrganizerOf(tournamentId) || isScorekeeper();
        }

        match /participant/{participantId} {
          allow read: if true;
          allow write: if isAdmin() || isOrganizerOf(tournamentId);
        }

        match /group/{groupId} {
          allow read: if true;
          allow write: if isAdmin() || isOrganizerOf(tournamentId);
        }

        match /round/{roundId} {
          allow read: if true;
          allow write: if isAdmin() || isOrganizerOf(tournamentId);
        }

        match /match_game/{gameId} {
          allow read: if true;
          allow write: if isAdmin() || isOrganizerOf(tournamentId) || isScorekeeper();
        }

        match /match_scores/{matchId} {
          allow read: if true;
          allow write: if isAdmin() || isOrganizerOf(tournamentId) || isScorekeeper();

          // Score correction history - readable by all, writable by scorekeepers only
          match /corrections/{correctionId} {
            allow read: if isAuthenticated();
            allow create: if isScorekeeper();
            allow update, delete: if false; // Immutable history
          }
        }

        // Level split configuration + generated level brackets
        match /levels/{levelId} {
          allow read: if true;
          allow write: if isAdmin() || isOrganizerOf(tournamentId);

          // Bracket subcollections under each level
          match /stage/{stageId} {
            allow read: if true;
            allow write: if isAdmin() || isOrganizerOf(tournamentId);
          }

          match /match/{matchId} {
            allow read: if true;
            allow write: if isAdmin() || isOrganizerOf(tournamentId) || isScorekeeper();
          }

          match /participant/{participantId} {
            allow read: if true;
            allow write: if isAdmin() || isOrganizerOf(tournamentId);
          }

          match /group/{groupId} {
            allow read: if true;
            allow write: if isAdmin() || isOrganizerOf(tournamentId);
          }

          match /round/{roundId} {
            allow read: if true;
            allow write: if isAdmin() || isOrganizerOf(tournamentId);
          }

          match /match_game/{gameId} {
            allow read: if true;
            allow write: if isAdmin() || isOrganizerOf(tournamentId) || isScorekeeper();
          }

          match /match_scores/{matchId} {
            allow read: if true;
            allow write: if isAdmin() || isOrganizerOf(tournamentId) || isScorekeeper();
          }
        }

        match /level_assignments/{assignmentId} {
          allow read: if true;
          allow write: if isAdmin() || isOrganizerOf(tournamentId);
        }

        match /level_generation/{configId} {
          allow read: if true;
          allow write: if isAdmin() || isOrganizerOf(tournamentId);
        }
      }

    }

    // Notifications collection
    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Only the system (functions) or admins can create notifications
      allow create: if isAdmin();
      // Users can update (mark as read) their own notifications
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Users can delete their own notifications
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Bug Reports collection
    match /bugReports/{reportId} {
      // Only admins can read all bug reports
      allow read: if isAdmin();
      // Authenticated users can create their own bug reports
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Only admins can update or delete
      allow update, delete: if isAdmin();
    }

    // Reviews collection (moderated via callable + admin tooling)
    match /reviews/{reviewId} {
      // Public can read only approved reviews; admins can read all
      allow read: if resource.data.status == 'approved' || isAdmin();
      // Direct writes are blocked; review creation runs via callable/admin SDK
      allow create: if false;
      allow update, delete: if isAdmin();
    }

    // ---- Global Player Identity ----

    function isOrgMember(orgId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    function isOrgAdmin(orgId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || isOrgMember(orgId);
      allow delete: if isAdmin();

      match /members/{uid} {
        allow read: if isAuthenticated();
        allow write: if isAdmin() || isOrgAdmin(orgId);
      }
    }

    match /players/{playerId} {
      allow read: if true;  // public player search at /find
      allow create: if isAuthenticated();
      allow update: if isAdmin()
        || (isOwner(resource.data.userId)
            && !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['isVerified', 'stats', 'identityStatus', 'mergedIntoPlayerId']));
      allow delete: if isAdmin();
    }

    match /mergeRequests/{requestId} {
      allow read: if isAdmin() || isOrganizer();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isOrganizer();
      allow delete: if isAdmin();
    }

    match /playerEmailIndex/{emailNormalized} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /orgSlugIndex/{slug} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // ---- Collection Group Query Rules ----
    // Required for collectionGroup() queries to work across subcollections.

    match /{path=**}/registrations/{registrationId} {
      allow read: if isAuthenticated();
    }

    match /{path=**}/activities/{activityId} {
      allow read: if isAuthenticated();
    }

    match /{path=**}/members/{uid} {
      allow read: if isAuthenticated();
    }
  }
}
