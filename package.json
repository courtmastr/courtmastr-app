{
  "name": "courtmaster-v2",
  "private": true,
  "version": "2.12.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:log": "node scripts/run-and-log.mjs vite",
    "hooks:enable": "git config core.hooksPath .githooks",
    "check:firebase-env": "node scripts/check-firebase-env.mjs --mode production",
    "build": "npm run check:firebase-env && vue-tsc -b && vite build",
    "build:log": "node scripts/run-and-log.mjs --shell \"npm run check:firebase-env && vue-tsc -b && vite build\"",
    "preview": "vite preview",
    "release:plan": "node scripts/release/release-cli.mjs plan",
    "release:deploy": "node scripts/release/release-cli.mjs deploy",
    "test": "vitest",
    "test:log": "node scripts/run-and-log.mjs vitest",
    "test:coverage": "vitest run --coverage",
    "report:tests": "node scripts/testing/generate-test-catalog-report.mjs",
    "verify:release": "node scripts/testing/verify-release.mjs",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "lint:check": "ESLINT_USE_FLAT_CONFIG=false eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore",
    "pre-pr": "npm run lint:check && npm run test -- --run && npm run build",
    "lint:log": "ESLINT_USE_FLAT_CONFIG=false node scripts/run-and-log.mjs eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "type-check": "vue-tsc --noEmit",
    "emulators": "npm run build --prefix functions && firebase emulators:start --project demo-courtmaster",
    "emulators:log": "node scripts/run-and-log.mjs --shell \"npm run build --prefix functions && firebase emulators:start --project demo-courtmaster\"",
    "emulators:capture": "node scripts/log-capture.mjs",
    "logs:view": "ls -t logs/ | head -10",
    "logs:tail": "tail -f logs/emulators-*.log 2>/dev/null || echo 'No log files found. Run emulators:capture first.'",
    "seed:local": "npx tsx scripts/seed/local.ts",
    "seed:prod": "npx tsx scripts/seed/production.ts",
    "seed:demo:local": "npx tsx scripts/seed/demo-local.ts",
    "seed:demo:prod": "npx tsx scripts/seed/demo-prod.ts",
    "seed:tnf2025:local": "npx tsx scripts/seed/tnf2025-local.ts",
    "seed:tnf2025:prod": "npx tsx scripts/seed/tnf2025-prod.ts",
    "seed:tnf2026:local": "npx tsx scripts/seed/tnf2026-local.ts",
    "seed:tnf2026:prod": "npx tsx scripts/seed/tnf2026-prod.ts",
    "seed:fix-tnf2026-wd:prod": "npx tsx scripts/seed/fix-tnf2026-wd-prod.ts",
    "seed:fix-tnf2026-md:prod": "npx tsx scripts/seed/fix-tnf2026-md-prod.ts",
    "seed:fix-tnf2026-mxd:prod": "npx tsx scripts/seed/fix-tnf2026-mxd-prod.ts",
    "seed:mcia2026:local": "npx tsx scripts/seed/mcia2026-local.ts",
    "seed:history:local": "npx tsx scripts/seed/history-test-local.ts",
    "seed:player-identity:local": "npx tsx scripts/seed/player-identity-local.ts",
    "results:mcia2026:local": "npx tsx scripts/mcia2026-results-local.ts",
    "seed:spring2025:local": "npx tsx scripts/seed/spring2025-local.ts",
    "seed:spring2025:prod": "npx tsx scripts/seed/spring2025-prod.ts",
    "start:dev": "node scripts/start-dev.mjs",
    "killall": "pkill -f 'firebase' 2>/dev/null; pkill -f 'vite' 2>/dev/null; pkill -f 'node.*emulator' 2>/dev/null || echo 'No processes found'",
    "deploy": "npm run build && firebase deploy --project production",
    "deploy:log": "node scripts/run-and-log.mjs --shell \"npm run build && firebase deploy --project production\"",
    "deploy:hosting": "npm run build && firebase deploy --only hosting --project production",
    "deploy:functions": "firebase deploy --only functions",
    "secrets:volunteer:check:prod": "firebase --project production functions:secrets:get VOLUNTEER_PIN_SECRET && firebase --project production functions:secrets:get VOLUNTEER_SESSION_SECRET",
    "deploy:functions:prod": "npm run secrets:volunteer:check:prod && firebase deploy --only functions --project production",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "e2e:clean": "rm -rf e2e-report test-results",
    "e2e": "npm run e2e:clean && playwright test",
    "e2e:list": "playwright test --list",
    "e2e:report": "playwright show-report e2e-report/html",
    "e2e:feature:smoke": "npm run e2e:clean && playwright test --project=feature-smoke",
    "e2e:feature:auth": "npm run e2e:clean && playwright test --project=feature-auth",
    "e2e:feature:registration": "npm run e2e:clean && playwright test --project=feature-registration",
    "e2e:feature:scoring": "npm run e2e:clean && playwright test --project=feature-scoring",
    "e2e:feature:tournament-admin": "npm run e2e:clean && playwright test --project=feature-tournament-admin",
    "e2e:feature:public": "npm run e2e:clean && playwright test --project=feature-public-leaderboard",
    "e2e:feature:regression": "npm run e2e:clean && playwright test --project=feature-regression",
    "e2e:compat": "npm run e2e:clean && playwright test --project=compat-desktop-chrome --project=compat-desktop-firefox --project=compat-desktop-webkit --project=compat-mobile-chrome --project=compat-mobile-webkit --project=compat-tablet-webkit --project=compat-landscape-chrome"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "brackets-manager": "^1.8.2",
    "brackets-viewer": "^1.9.0",
    "date-fns": "^4.1.0",
    "firebase": "^12.8.0",
    "gsap": "^3.15.0",
    "html2canvas": "^1.4.1",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4",
    "vuedraggable": "^4.1.0",
    "vuefire": "^3.2.2",
    "vuetify": "^3.11.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "brackets-memory-db": "^1.0.5",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "firebase-tools": "^15.5.1",
    "happy-dom": "^20.3.7",
    "playwright": "^1.58.1",
    "sass": "^1.97.3",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.1.4"
  }
}
